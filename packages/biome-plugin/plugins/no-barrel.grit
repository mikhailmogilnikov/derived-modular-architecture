language js;

or {
  `export { $names } from $source`,
  `export * from $source`,
  `export type { $names } from $source`
} where {
  register_diagnostic(
    span = $source,
    message = "Barrel re-export file in a DMA module (no-barrel). Import public files by direct path instead.",
    severity = "error"
  )
}
