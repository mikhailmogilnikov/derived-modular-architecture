{
  "root": true,
  "plugins": [
    {
      "path": "./plugins/no-barrel.grit",
      "includes": [
        "**/features/**/index.ts",
        "**/features/**/index.tsx",
        "**/services/**/index.ts",
        "**/services/**/index.tsx"
      ]
    },
    {
      "path": "./plugins/feature-to-feature.grit",
      "includes": ["**/features/**"]
    },
    {
      "path": "./plugins/layer-direction.grit",
      "includes": ["**/features/**", "**/services/**", "**/shared/**"]
    },
    {
      "path": "./plugins/public-api.grit",
      "includes": ["**/src/**"]
    }
  ],
  "linter": { "enabled": true },
  "formatter": { "enabled": false },
  "assist": { "enabled": false }
}
