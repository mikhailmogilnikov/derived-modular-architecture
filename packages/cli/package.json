{
  "name": "@derived-modular/cli",
  "version": "1.2.2",
  "description": "Derived Modular Architecture checker and doctor CLI",
  "type": "module",
  "bin": {
    "dma": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun ./scripts/build.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "check-types": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@derived-modular/boundaries": "workspace:*",
    "jiti": "^2.7.0",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest"
  },
  "keywords": [
    "architecture",
    "dma",
    "lint",
    "modules",
    "cli"
  ],
  "license": "MIT",
  "author": "Mikhail Mogilnikov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikhailmogilnikov/derived-modular-architecture.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/mikhailmogilnikov/derived-modular-architecture/tree/main/packages/cli#readme",
  "bugs": "https://github.com/mikhailmogilnikov/derived-modular-architecture/issues",
  "publishConfig": {
    "access": "public"
  }
}
