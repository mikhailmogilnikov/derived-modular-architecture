{
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "lefthook": "^2.1.10",
    "turbo": "^2.10.4",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  },
  "name": "dma",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dma": "bun packages/cli/src/cli/main.ts",
    "dma:build": "bun run --cwd packages/cli build",
    "upgrade": "ncu -u",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14"
    }
  }
}
