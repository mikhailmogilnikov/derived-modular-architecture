{
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "lefthook": "^2.1.10",
    "turbo": "^2.10.4",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  },
  "name": "dma",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dma": "bun packages/cli/src/cli/main.ts",
    "dma:build": "turbo run build",
    "upgrade": "ncu -u",
    "check": "ultracite check",
    "dma-check:examples": "turbo run dma-check --filter=\"./examples/*\"",
    "fix": "ultracite fix",
    "commitlint": "commitlint --edit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "lefthook install"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "private": true,
  "packageManager": "bun@1.3.14",
  "license": "MIT",
  "author": "Mikhail Mogilnikov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikhailmogilnikov/derived-modular-architecture.git"
  },
  "homepage": "https://github.com/mikhailmogilnikov/derived-modular-architecture#readme",
  "bugs": "https://github.com/mikhailmogilnikov/derived-modular-architecture/issues",
  "engines": {
    "node": ">=18"
  }
}
