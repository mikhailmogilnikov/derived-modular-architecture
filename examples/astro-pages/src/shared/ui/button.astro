---
interface Props {
	label: string;
}

const { label } = Astro.props;
---

<button type="button" class="dma-button">{label}</button>

<style>
	.dma-button {
		padding: 0.5rem 1rem;
		border-radius: 0.375rem;
		border: 1px solid #2563eb;
		background: #2563eb;
		color: #fff;
		font: inherit;
		cursor: pointer;
	}

	.dma-button:hover {
		background: #1d4ed8;
		border-color: #1d4ed8;
	}
</style>
